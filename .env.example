# Environment Variables
# Copy to .env.local and fill in values

# Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
PLATFORM_TRUST_SUPABASE_URL=
# Use sb_secret_ format (new Supabase key format)
SUPABASE_SERVICE_ROLE_KEY=

# AI / API Keys
ADMIN_API_KEY=
DATAWIZZ_API_KEY=

# ElevenLabs — server-only (NO NEXT_PUBLIC_ prefix).
# ELEVENLABS_API_KEY: the operator's ElevenLabs API key. NEVER expose client-side.
# ELEVENLABS_WEBHOOK_SECRET: captured at webhook creation in ElevenLabs dashboard.
#   Must be set for webhook HMAC verification (VMS rule 10). Unset → 403 on every webhook.
# ELEVENLABS_AGENT_*: agent IDs — server-only, resolved via voice.config.ts.
#   Do NOT add NEXT_PUBLIC_ prefixes to these.
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=
ELEVENLABS_AGENT_SETUP=
ELEVENLABS_AGENT_BASICS=
ELEVENLABS_AGENT_PROPERTY=
ELEVENLABS_AGENT_FINANCIAL=
ELEVENLABS_AGENT_DERISK=
ELEVENLABS_AGENT_ASSESSMENT=

# Stripe
STRIPE_PRICE_FREE_MONTHLY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_YEARLY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Platform Trust
PLATFORM_TRUST_PROJECT_ID=
PLATFORM_TRUST_SERVICE_KEY=

# App
ADMIN_DASHBOARD_URL=
APP_URL=
DATAWIZZ_BASE_URL=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_PROPERTY_SERVICES_URL=

# Other
ABR_GUID=
DATAWIZZ_MODEL=
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_PROPERTY_SERVICES_ANON_KEY=

# Portfolio Standard R11 — vendor identity routed through env vars.
# Replace the placeholders with the consuming brand's identity, or leave
# them as-is for a vendor-neutral white-label deploy.
NEXT_PUBLIC_VENDOR_NAME="Your Brand Here"
NEXT_PUBLIC_VENDOR_EMAIL="hello@yourbrand.com"
NEXT_PUBLIC_VENDOR_PHONE=""
NEXT_PUBLIC_VENDOR_CALENDLY=""
NEXT_PUBLIC_VENDOR_INSTAGRAM=""

# Portfolio Standard R6 — verified Resend subdomain (never the bare
# corporateaisolutions.com — not verified, silently fails delivery).
RESEND_FROM_EMAIL=noreply@updates.corporateaisolutions.com
