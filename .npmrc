@caistech:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
always-auth=true
# Tolerate the pre-existing lucide-react peer-range mismatch between the root (0.303.x) and
# @caistech/corporate-components (peer >=0.400). Surfaced when package.json changed without a lock
# update → ERESOLVE on Vercel's npm install. legacy-peer-deps restores the prior behaviour.
legacy-peer-deps=true
